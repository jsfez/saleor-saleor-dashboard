API_URL=http://localhost:8000/graphql/
APP_MOUNT_URI=/
# Provides source for App Store / explore feature. Only for Saleor Cloud
# EXTENSIONS_API_URL=https://apps.saleor.io/api/v1/extensions
# Domain that hosts first-party Saleor Cloud apps. Extensions whose URL is not under this domain are considered external.
SALEOR_CLOUD_APP_DOMAIN=saleor.app
LOCALE_CODE="EN"

# Multi-schema support (optional)
# Set to "true" to use staging schema instead of main schema
# See docs/multi-schema.md
FF_USE_STAGING_SCHEMA=false

MAILPITURL=xxxx #For playwright

E2E_USER_NAME=xxxx
E2E_USER_PASSWORD=xxxx
E2E_PERMISSIONS_USERS_PASSWORD=xxxx
BASE_URL=http://localhost:9000/

ONBOARDING_USER_JOINED_DATE_THRESHOLD=2024-07-01

# Deprecated Saleor version banner (optional)
# When the connected Saleor version is the same or older than DEPRECATED_SALEOR_VERSION
# (compared on major.minor only), a banner is shown in the sidebar informing users that
# the instance will be automatically upgraded on DEPRECATED_SALEOR_VERSION_TIMESTAMP.
# Both variables must be set and valid, otherwise the banner is disabled.
# DEPRECATED_SALEOR_VERSION must be "<major>.<minor>" (e.g. 3.20).
# DEPRECATED_SALEOR_VERSION_TIMESTAMP must be an ISO date or timestamp (only the date is rendered).
# DEPRECATED_SALEOR_VERSION=3.20
# DEPRECATED_SALEOR_VERSION_TIMESTAMP=2026-09-01
